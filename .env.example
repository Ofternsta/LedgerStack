# Supabase (Project → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App URL (must match Supabase Auth redirect URLs)
# Local: http://localhost:3000
# Production: https://ledgerstack.org
# Public support inbox (also in lib/support.ts): support@ledgerstack.org
# Supabase → Authentication → URL Configuration: add
#   {APP_URL}/auth/callback
#   {APP_URL}/login/reset-password
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Shown on Privacy Policy / Terms (your legal name or company name)
# NEXT_PUBLIC_LEGAL_OPERATOR_NAME=Your Name or LLC

# SEO — Google Search Console HTML tag verification (optional)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Auth verification emails (recommended — see SUPABASE_AUTH_EMAIL.md)
# RESEND_API_KEY=re_...
# AUTH_EMAIL_FROM=noreply@ledgerstack.org
# AUTH_EMAIL_SENDER_NAME=LedgerStack auth
# AUTH_EMAIL_APP_NAME=LedgerStack

# AI (Groq)
GROQ_API_KEY=

# SignWell e-signatures (see SIGNWELL.md)
# SIGNWELL_API_KEY=
# SIGNWELL_TEST_MODE=true

# Platform owner — only this email can delete accounts at /settings/users
PLATFORM_OWNER_EMAIL=

# Stripe — see STRIPE.md for dashboard setup
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_ENTERPRISE=
# Optional branding (defaults: LedgerStack / LEDGERSTACK)
# STRIPE_CHECKOUT_DISPLAY_NAME=LedgerStack
# STRIPE_STATEMENT_DESCRIPTOR=LedgerStack
# STRIPE_STATEMENT_DESCRIPTOR_SUFFIX=LEDGERSTACK
# Customer portal: payment + invoices only (subscription updates disabled) — see STRIPE.md
# STRIPE_PORTAL_CONFIGURATION_BILLING_ONLY=bpc_...
# Optional: portal config with plan changes enabled (if default portal has updates off)
# STRIPE_PORTAL_CONFIGURATION_PLAN_CHANGE=bpc_...

# Encrypts passwords for paid signup pending rows (16+ random characters).
# Must be set on Vercel — same value for signup API and Stripe webhook.
PENDING_SIGNUP_SECRET=
